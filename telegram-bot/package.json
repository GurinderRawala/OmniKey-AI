{
  "name": "telegram-bot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "daemon": "node dist/daemon.js",
    "daemon:start": "yarn build && node dist/daemon.js start",
    "daemon:stop": "node dist/daemon.js stop",
    "daemon:restart": "yarn build && node dist/daemon.js restart",
    "daemon:status": "node dist/daemon.js status",
    "daemon:logs": "node dist/daemon.js logs",
    "daemon:uninstall": "node dist/daemon.js uninstall"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.1.4",
    "express": "^4.18.2",
    "node-telegram-bot-api": "^0.61.0",
    "winston": "^3.17.0",
    "ws": "^8",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.2",
    "@types/node-telegram-bot-api": "^0.57.0",
    "@types/ws": "^8.18.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.6"
  },
  "packageManager": "yarn@1.22.22"
}
