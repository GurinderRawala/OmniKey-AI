<Page
    x:Class="OmniKey.Windows.Views.Pages.ManualPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Manual"
    Background="Transparent"
    d:DesignHeight="700"
    d:DesignWidth="980"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ────────────────── Header ────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="20"
                    Foreground="{StaticResource Nord.AccentBrush}"
                    Symbol="Book24" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource OK.FontFamily}"
                    FontSize="{StaticResource OK.Font.Title}"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Nord.PrimaryTextBrush}"
                    Text="OmniKey Manual" />
            </StackPanel>
            <TextBlock
                Margin="0,4,0,0"
                FontFamily="{StaticResource OK.FontFamily}"
                FontSize="{StaticResource OK.Font.Body}"
                Foreground="{StaticResource Nord.SecondaryTextBrush}"
                Text="{Binding Tagline}"
                TextWrapping="Wrap" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Height="1"
            Margin="0,0,0,14"
            Background="{StaticResource Nord.BorderBrush}" />

        <!-- ────────────────── Scrollable content ────────────────── -->
        <ScrollViewer
            Grid.Row="2"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,8">

                <!-- ─── Shortcuts card ─── -->
                <Border
                    Margin="0,0,0,16"
                    Padding="20,18,20,12"
                    Background="{StaticResource Nord.PanelBackgroundBrush}"
                    CornerRadius="14">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="22"
                            Direction="270"
                            Opacity="0.45"
                            ShadowDepth="6"
                            Color="Black" />
                    </Border.Effect>

                    <StackPanel>
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <ui:SymbolIcon
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{StaticResource Nord.AccentAmberBrush}"
                                Symbol="Keyboard24" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.Headline}"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource Nord.AccentBlueBrush}"
                                Text="Keyboard shortcuts" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Shortcuts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <ui:SymbolIcon
                                            Grid.Column="0"
                                            Margin="0,2,12,0"
                                            VerticalAlignment="Top"
                                            FontSize="18"
                                            Foreground="{StaticResource Nord.AccentBrush}"
                                            Symbol="{Binding Icon}" />

                                        <!-- Key chip -->
                                        <Border
                                            Grid.Column="1"
                                            Margin="0,1,14,0"
                                            Padding="8,3,8,4"
                                            VerticalAlignment="Top"
                                            Background="{StaticResource Nord.EditorBackgroundBrush}"
                                            BorderBrush="{StaticResource Nord.BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <TextBlock
                                                FontFamily="{StaticResource OK.MonoFontFamily}"
                                                FontSize="{StaticResource OK.Font.Caption}"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource Nord.AccentAmberBrush}"
                                                Text="{Binding Keys}" />
                                        </Border>

                                        <!-- Label + description -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock
                                                FontFamily="{StaticResource OK.FontFamily}"
                                                FontSize="{StaticResource OK.Font.Body}"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                                Text="{Binding Title}" />
                                            <TextBlock
                                                Margin="0,2,0,0"
                                                FontFamily="{StaticResource OK.FontFamily}"
                                                FontSize="{StaticResource OK.Font.Caption}"
                                                Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                                Text="{Binding Description}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ─── Documentation sections ─── -->
                <ItemsControl ItemsSource="{Binding Sections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,14"
                                Padding="20,16,20,18"
                                Background="{StaticResource Nord.PanelBackgroundBrush}"
                                CornerRadius="14">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="22"
                                        Direction="270"
                                        Opacity="0.45"
                                        ShadowDepth="6"
                                        Color="Black" />
                                </Border.Effect>

                                <StackPanel>
                                    <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                        <ui:SymbolIcon
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            FontSize="16"
                                            Foreground="{StaticResource Nord.AccentBrush}"
                                            Symbol="{Binding Icon}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource OK.FontFamily}"
                                            FontSize="{StaticResource OK.Font.Headline}"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource Nord.AccentBlueBrush}"
                                            Text="{Binding Title}" />
                                    </StackPanel>
                                    <TextBlock
                                        FontFamily="{StaticResource OK.FontFamily}"
                                        FontSize="{StaticResource OK.Font.Body}"
                                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                        LineHeight="20"
                                        Text="{Binding Body}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
