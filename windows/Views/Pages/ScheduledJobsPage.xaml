<Page
    x:Class="OmniKey.Windows.Views.Pages.ScheduledJobsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:OmniKey.Windows.ViewModels"
    Title="Scheduled Jobs"
    Background="Transparent"
    d:DesignHeight="720"
    d:DesignWidth="1080"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ────────────────── Header ────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="{StaticResource Nord.AccentBrush}"
                        Symbol="Calendar24" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="{StaticResource OK.Font.Title}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                        Text="Scheduled Jobs" />
                </StackPanel>
                <TextBlock
                    Margin="0,4,0,0"
                    FontFamily="{StaticResource OK.FontFamily}"
                    FontSize="{StaticResource OK.Font.Body}"
                    Foreground="{StaticResource Nord.SecondaryTextBrush}"
                    Text="Schedule prompts to run automatically. The system will wake your PC if needed." />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <ui:Button
                    Margin="0,0,8,0"
                    Command="{Binding RefreshCommand}"
                    Content="Refresh"
                    Icon="{ui:SymbolIcon Symbol=ArrowSync24}" />
                <ui:Button
                    Appearance="Primary"
                    Command="{Binding NewJobCommand}"
                    Content="Add job"
                    Icon="{ui:SymbolIcon Symbol=Add24}" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Height="1"
            Margin="0,0,0,14"
            Background="{StaticResource Nord.BorderBrush}" />

        <!-- ────────────────── Master / Detail body ────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="280" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ───────── Left: job list ───────── -->
            <Border
                Grid.Column="0"
                Padding="6"
                Background="{StaticResource Nord.PanelBackgroundBrush}"
                CornerRadius="14">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="22"
                        Direction="270"
                        Opacity="0.45"
                        ShadowDepth="6"
                        Color="Black" />
                </Border.Effect>

                <Grid>
                    <ListBox
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalContentAlignment="Stretch"
                        ItemsSource="{Binding Jobs}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        SelectedItem="{Binding SelectedJob, Mode=TwoWay}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,8" />
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Nord.EditorBackgroundBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Nord.EditorBackgroundBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource Nord.AccentBlueBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ScheduledJobItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <ui:ToggleSwitch
                                        Grid.Column="0"
                                        Margin="0,2,10,0"
                                        VerticalAlignment="Top"
                                        IsChecked="{Binding IsActive, Mode=TwoWay}" />

                                    <StackPanel Grid.Column="1">
                                        <TextBlock
                                            FontFamily="{StaticResource OK.FontFamily}"
                                            FontSize="{StaticResource OK.Font.Headline}"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                            Text="{Binding Label}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            FontFamily="{StaticResource OK.FontFamily}"
                                            FontSize="{StaticResource OK.Font.Caption}"
                                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                            Text="{Binding ScheduleSummary}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            FontFamily="{StaticResource OK.FontFamily}"
                                            FontSize="{StaticResource OK.Font.CaptionSmall}"
                                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                            Opacity="0.85"
                                            Text="{Binding NextRunSummary}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontFamily="{StaticResource OK.FontFamily}"
                                            FontSize="{StaticResource OK.Font.CaptionSmall}"
                                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                            Opacity="0.7"
                                            Text="{Binding PromptExcerpt}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ───────── Right: editor / empty state ───────── -->
            <Border
                Grid.Column="2"
                Padding="20"
                Background="{StaticResource Nord.PanelBackgroundBrush}"
                CornerRadius="14">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="22"
                        Direction="270"
                        Opacity="0.45"
                        ShadowDepth="6"
                        Color="Black" />
                </Border.Effect>

                <Grid>
                    <!-- Empty state -->
                    <StackPanel
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding ShowEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:SymbolIcon
                            HorizontalAlignment="Center"
                            FontSize="36"
                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                            Symbol="Calendar24" />
                        <TextBlock
                            Margin="0,12,0,4"
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource OK.FontFamily}"
                            FontSize="{StaticResource OK.Font.Title}"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource Nord.PrimaryTextBrush}"
                            Text="No job selected" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource OK.FontFamily}"
                            FontSize="{StaticResource OK.Font.Body}"
                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                            Text="Pick a job on the left or create a new one to start editing." />
                        <ui:Button
                            Margin="0,18,0,0"
                            HorizontalAlignment="Center"
                            Appearance="Primary"
                            Command="{Binding NewJobCommand}"
                            Content="Add job"
                            Icon="{ui:SymbolIcon Symbol=Add24}" />
                    </StackPanel>

                    <!-- Editor -->
                    <Grid Visibility="{Binding HasSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Title + active toggle. The Active control is laid out
                             as a labelled toggle in a Border on the right so it
                             aligns with the TextBox baseline cleanly (rather than
                             dangling alongside the LABEL eyebrow). -->
                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.Eyebrow}"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                Text="LABEL" />

                            <ui:TextBox
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,4,12,0"
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.Body}"
                                PlaceholderText="Friendly name (e.g. Morning standup digest)"
                                Text="{Binding EditorLabel, UpdateSourceTrigger=PropertyChanged}" />

                            <Border
                                Grid.Row="1"
                                Grid.Column="1"
                                Padding="10,6"
                                VerticalAlignment="Center"
                                Background="{StaticResource Nord.EditorBackgroundBrush}"
                                BorderBrush="{StaticResource Nord.BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource OK.FontFamily}"
                                        FontSize="{StaticResource OK.Font.Caption}"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                        Text="Active" />
                                    <ui:ToggleSwitch
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding EditorIsActive, Mode=TwoWay}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Last / next run summary -->
                        <Border
                            Grid.Row="1"
                            Margin="0,0,0,12"
                            Padding="12,10"
                            Background="{StaticResource Nord.EditorBackgroundBrush}"
                            CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontFamily="{StaticResource OK.FontFamily}"
                                        FontSize="{StaticResource OK.Font.Eyebrow}"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                        Text="LAST RUN" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontFamily="{StaticResource OK.FontFamily}"
                                        FontSize="{StaticResource OK.Font.Body}"
                                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                        Text="{Binding EditorLastRunSummary}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock
                                        FontFamily="{StaticResource OK.FontFamily}"
                                        FontSize="{StaticResource OK.Font.Eyebrow}"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                        Text="NEXT RUN" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontFamily="{StaticResource OK.FontFamily}"
                                        FontSize="{StaticResource OK.Font.Body}"
                                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                        Text="{Binding EditorNextRunSummary}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Prompt editor -->
                        <Grid Grid.Row="2" Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Margin="0,0,0,4"
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.Eyebrow}"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                Text="PROMPT" />
                            <Border
                                Grid.Row="1"
                                BorderBrush="{StaticResource Nord.BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <ui:TextBox
                                    AcceptsReturn="True"
                                    AcceptsTab="True"
                                    Background="{StaticResource Nord.EditorBackgroundBrush}"
                                    BorderThickness="0"
                                    FontFamily="{StaticResource OK.MonoFontFamily}"
                                    FontSize="13"
                                    Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                    PlaceholderText="What should the assistant do when this job runs?"
                                    Text="{Binding EditorPrompt, UpdateSourceTrigger=PropertyChanged}"
                                    TextWrapping="Wrap"
                                    VerticalScrollBarVisibility="Auto" />
                            </Border>
                        </Grid>

                        <!-- Schedule kind selector -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,10">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.Eyebrow}"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                Text="SCHEDULE" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton
                                    Margin="0,0,18,0"
                                    Content="Recurring (cron)"
                                    FontFamily="{StaticResource OK.FontFamily}"
                                    FontSize="{StaticResource OK.Font.Body}"
                                    Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                    GroupName="ScheduleKind"
                                    IsChecked="{Binding IsRecurring, Mode=TwoWay}" />
                                <RadioButton
                                    Content="One-shot"
                                    FontFamily="{StaticResource OK.FontFamily}"
                                    FontSize="{StaticResource OK.Font.Body}"
                                    Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                    GroupName="ScheduleKind"
                                    IsChecked="{Binding IsOneShot, Mode=TwoWay}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Recurring fields -->
                        <Grid
                            Grid.Row="4"
                            Margin="0,0,0,10"
                            Visibility="{Binding IsRecurring, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ui:TextBox
                                Grid.Row="0"
                                FontFamily="{StaticResource OK.MonoFontFamily}"
                                FontSize="13"
                                PlaceholderText="Cron expression (e.g. 0 9 * * 1-5)"
                                Text="{Binding EditorCron, UpdateSourceTrigger=PropertyChanged}" />
                            <ItemsControl
                                Grid.Row="1"
                                Margin="0,8,0,0"
                                ItemsSource="{Binding CronPresets}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Button
                                            Margin="0,0,6,6"
                                            Command="{Binding DataContext.ApplyCronPresetCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding Value}"
                                            Content="{Binding Label}"
                                            FontSize="{StaticResource OK.Font.CaptionSmall}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!-- One-shot fields -->
                        <StackPanel
                            Grid.Row="5"
                            Margin="0,0,0,10"
                            Orientation="Horizontal"
                            Visibility="{Binding IsOneShot, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DatePicker
                                Width="180"
                                Margin="0,0,8,0"
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.Body}"
                                SelectedDate="{Binding EditorRunAtDate, Mode=TwoWay}" />
                            <ui:TextBox
                                Width="120"
                                FontFamily="{StaticResource OK.MonoFontFamily}"
                                FontSize="13"
                                PlaceholderText="HH:mm"
                                Text="{Binding EditorRunAtTime, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <!-- Action bar. Visual hierarchy:
                             • Save (primary, blue) is the prominent right-aligned action.
                             • Run now (secondary) sits beside it for quick testing.
                             • Reset is a low-emphasis ghost button.
                             • Delete is a ghost-red destructive action on the far left,
                               visually quieter than the primary action so it can't be
                               clicked by mistake. -->
                        <Grid Grid.Row="6" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ui:Button
                                Grid.Column="0"
                                Command="{Binding DeleteCommand}"
                                Content="Delete"
                                Icon="{ui:SymbolIcon Symbol=Delete24}"
                                Style="{StaticResource OK.DangerGhostButtonStyle}"
                                ToolTip="Delete this scheduled job" />

                            <StackPanel
                                Grid.Column="2"
                                Orientation="Horizontal">
                                <ui:Button
                                    Margin="0,0,6,0"
                                    Appearance="Transparent"
                                    Command="{Binding CancelEditCommand}"
                                    Content="Reset"
                                    ToolTip="Discard edits" />
                                <ui:Button
                                    Margin="0,0,6,0"
                                    Appearance="Secondary"
                                    Command="{Binding RunNowCommand}"
                                    Content="Run now"
                                    Icon="{ui:SymbolIcon Symbol=Play24}"
                                    ToolTip="Run this job immediately" />
                                <ui:Button
                                    Appearance="Primary"
                                    Command="{Binding SaveCommand}"
                                    Content="Save"
                                    Icon="{ui:SymbolIcon Symbol=Save24}"
                                    ToolTip="Save changes" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ────────────────── Status row ────────────────── -->
        <StackPanel
            Grid.Row="3"
            Margin="0,14,0,0"
            Orientation="Horizontal">
            <ui:ProgressRing
                Width="16"
                Height="16"
                Margin="0,0,8,0"
                IsIndeterminate="True"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <TextBlock
                VerticalAlignment="Center"
                FontFamily="{StaticResource OK.FontFamily}"
                FontSize="{StaticResource OK.Font.CaptionSmall}"
                Foreground="{Binding StatusBrush}"
                Text="{Binding StatusMessage}"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</Page>
