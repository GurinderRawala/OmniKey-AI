<Page
    x:Class="OmniKey.Windows.Views.Pages.JobRunHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Job Run History"
    Background="Transparent"
    d:DesignHeight="720"
    d:DesignWidth="1100"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ────────────────── Header ────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="{StaticResource Nord.AccentBrush}"
                        Symbol="History24" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="{StaticResource OK.Font.Title}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                        Text="Job Run History" />
                </StackPanel>
                <TextBlock
                    Margin="0,4,0,0"
                    FontFamily="{StaticResource OK.FontFamily}"
                    FontSize="{StaticResource OK.Font.Body}"
                    Foreground="{StaticResource Nord.SecondaryTextBrush}"
                    Text="Browse past scheduled-job runs and review the steps the agent took on each one." />
            </StackPanel>

            <ui:Button
                Grid.Column="1"
                VerticalAlignment="Center"
                Command="{Binding RefreshCommand}"
                Content="Refresh"
                Icon="{ui:SymbolIcon Symbol=ArrowClockwise24}" />
        </Grid>

        <Border
            Grid.Row="1"
            Height="1"
            Margin="0,0,0,14"
            Background="{StaticResource Nord.BorderBrush}" />

        <!-- ────────────────── Master / Detail ────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="280" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- ── Master list ── -->
            <Border
                Grid.Column="0"
                Padding="0"
                Background="{StaticResource Nord.PanelBackgroundBrush}"
                CornerRadius="14">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="22"
                        Direction="270"
                        Opacity="0.45"
                        ShadowDepth="6"
                        Color="Black" />
                </Border.Effect>
                <Grid>
                    <!-- Loading indicator -->
                    <Grid
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding IsLoadingList, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center">
                            <ui:ProgressRing
                                Width="32"
                                Height="32"
                                IsIndeterminate="True" />
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.Caption}"
                                Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                Text="Loading runs…" />
                        </StackPanel>
                    </Grid>

                    <!-- Empty state -->
                    <StackPanel
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="20"
                        Visibility="{Binding ShowEmptyList, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:SymbolIcon
                            HorizontalAlignment="Center"
                            FontSize="34"
                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                            Symbol="History24" />
                        <TextBlock
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource OK.FontFamily}"
                            FontSize="{StaticResource OK.Font.Body}"
                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                            Text="No job runs yet." />
                    </StackPanel>

                    <!-- Master list -->
                    <ListBox
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding Runs}"
                        SelectedItem="{Binding SelectedRun}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        Visibility="{Binding HasRuns, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="8,6,8,0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border
                                                x:Name="Bd"
                                                Padding="12"
                                                Background="{StaticResource Nord.EditorBackgroundBrush}"
                                                BorderBrush="{StaticResource Nord.BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Nord.AccentBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Nord.AccentBrush}" />
                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="1.5" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- Top row: status badge + timestamp -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <ui:SymbolIcon
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                Foreground="{Binding StatusBrush}"
                                                Symbol="{Binding StatusSymbol}" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource OK.FontFamily}"
                                                FontSize="{StaticResource OK.Font.CaptionSmall}"
                                                FontWeight="SemiBold"
                                                Foreground="{Binding StatusBrush}"
                                                Text="{Binding StatusText}" />
                                        </StackPanel>
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource OK.FontFamily}"
                                            FontSize="{StaticResource OK.Font.CaptionSmall}"
                                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                            Text="{Binding TimestampDisplay}"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>

                                    <!-- Label -->
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontFamily="{StaticResource OK.FontFamily}"
                                        FontSize="{StaticResource OK.Font.Headline}"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                        Text="{Binding Label}"
                                        TextTrimming="CharacterEllipsis" />

                                    <!-- Prompt excerpt -->
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontFamily="{StaticResource OK.FontFamily}"
                                        FontSize="{StaticResource OK.Font.Caption}"
                                        Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                        Text="{Binding PromptExcerpt}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ── Detail pane ── -->
            <Border
                Grid.Column="2"
                Padding="20"
                Background="{StaticResource Nord.PanelBackgroundBrush}"
                CornerRadius="14">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="22"
                        Direction="270"
                        Opacity="0.45"
                        ShadowDepth="6"
                        Color="Black" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Detail header -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.Headline}"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                Text="{Binding DetailHeading}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Margin="0,2,0,0"
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.CaptionSmall}"
                                Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                Text="{Binding DetailSubheading}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>

                    <!-- Detail body -->
                    <Grid Grid.Row="1">
                        <!-- Loading -->
                        <StackPanel
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding IsLoadingDetail, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:ProgressRing
                                Width="36"
                                Height="36"
                                IsIndeterminate="True" />
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.Caption}"
                                Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                Text="Loading transcript…" />
                        </StackPanel>

                        <!-- Empty state (no selection) -->
                        <StackPanel
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding ShowEmptyDetail, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:SymbolIcon
                                HorizontalAlignment="Center"
                                FontSize="40"
                                Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                Symbol="DocumentSearch24" />
                            <TextBlock
                                Margin="0,12,0,0"
                                HorizontalAlignment="Center"
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.Body}"
                                Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                Text="Select a run on the left to view its transcript." />
                        </StackPanel>

                        <!-- Transcript sections -->
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="{Binding HasTranscript, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding TranscriptSections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,12"
                                            Padding="14"
                                            Background="{StaticResource Nord.EditorBackgroundBrush}"
                                            BorderBrush="{StaticResource Nord.BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                            <Grid>
                                                <StackPanel>
                                                    <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                                        <ui:SymbolIcon
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            FontSize="16"
                                                            Foreground="{Binding HeaderBrush}"
                                                            Symbol="{Binding HeaderSymbol}" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontFamily="{StaticResource OK.FontFamily}"
                                                            FontSize="{StaticResource OK.Font.Headline}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{Binding HeaderBrush}"
                                                            Text="{Binding Header}" />
                                                    </StackPanel>
                                                    <TextBlock
                                                        FontFamily="{StaticResource OK.FontFamily}"
                                                        FontSize="{StaticResource OK.Font.Body}"
                                                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                                        Text="{Binding Body}"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                                <!-- Inline copy icon — only on the Final Answer card -->
                                                <ui:Button
                                                    Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Appearance="Transparent"
                                                    Command="{Binding DataContext.CopyFinalAnswerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    Icon="{ui:SymbolIcon Symbol=Copy24, FontSize=14}"
                                                    ToolTip="Copy final answer"
                                                    Visibility="{Binding IsFinalAnswer, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ────────────────── Status bar ────────────────── -->
        <StackPanel
            Grid.Row="3"
            Margin="0,14,0,0"
            Orientation="Horizontal">
            <ui:ProgressRing
                Width="14"
                Height="14"
                Margin="0,0,8,0"
                IsIndeterminate="True"
                Visibility="{Binding IsLoadingList, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <TextBlock
                VerticalAlignment="Center"
                FontFamily="{StaticResource OK.FontFamily}"
                FontSize="{StaticResource OK.Font.CaptionSmall}"
                Foreground="{Binding StatusBrush}"
                Text="{Binding StatusMessage}"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</Page>
