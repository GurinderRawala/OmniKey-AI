<Page
    x:Class="OmniKey.Windows.Views.Pages.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:OmniKey.Windows.ViewModels"
    xmlns:om="clr-namespace:OmniKey.Windows"
    xmlns:md="clr-namespace:OmniKey.Windows.MarkdownRender"
    xmlns:ctl="clr-namespace:OmniKey.Windows.Controls"
    Title="Agent Chat"
    Background="Transparent"
    d:DesignHeight="760"
    d:DesignWidth="1180"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">

    <Page.Resources>
        <!--
            All chat surface brushes now live in Themes/NordTheme.xaml so
            every page stays in lockstep. Active session indicator uses the
            global accent (lavender) instead of a one-off blue.
        -->

        <!-- Modern ghost copy button. We use a plain WPF Button with a
             hand-rolled template rather than ui:Button + Appearance="Transparent",
             because the Wpf.Ui transparent appearance still resolves a
             theme-aware background that renders as a light card against
             our dark chat surface. The two icons (Copy + green Checkmark)
             are stacked inside the button and their Visibility is flipped
             by the ChatMessageRow.JustCopied flag. ToolTip swaps
             "Copy" → "Copied!" so the user gets text feedback too. -->
        <Style x:Key="Chat.CopyButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="Copy" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource Nord.HoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding JustCopied}" Value="True">
                    <Setter Property="ToolTip" Value="Copied!" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Per-block timeline row template. Click to expand/collapse.
             The dot lives in the SAME grid row as the header button (both
             VerticalAlignment="Center") so they share an exact vertical
             centerline — the previous layout had the dot in its own
             Auto row above the button, which made it sit ~2-3 px high
             relative to the icon/label baseline. -->
        <DataTemplate x:Key="TimelineRowTemplate" DataType="{x:Type vm:ChatBlockRow}">
            <!-- Bottom margin gives each thinking step breathing room
                 (matches macOS ThinkingSectionView VStack spacing: 10).
                 Previously rows abutted with 0 gap which read as a
                 cramped wall. -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <!-- Header (dot + button). -->
                    <RowDefinition Height="Auto" />
                    <!-- Optional expanded body. -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Dot — vertically centered against the header button. -->
                <Grid
                    Grid.Row="0"
                    Grid.Column="0"
                    Width="20"
                    Height="20"
                    VerticalAlignment="Center">
                    <Ellipse
                        Width="14"
                        Height="14"
                        Fill="{Binding AccentBrush}"
                        Opacity="0.22"
                        Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Ellipse
                        Width="6"
                        Height="6"
                        Fill="{Binding AccentBrush}">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Opacity" Value="0.35" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Opacity" Value="1.0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </Grid>

                <!-- Connector — only when this row is expanded, descending
                     from the dot to the bottom of the expanded body. -->
                <Rectangle
                    Grid.Row="1"
                    Grid.Column="0"
                    Width="1"
                    Margin="0,2,0,0"
                    HorizontalAlignment="Center"
                    Fill="{StaticResource Nord.BorderBrush}"
                    Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!-- Header button: icon + label + summary + chevron. -->
                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="6,0,0,0"
                    Padding="2,4"
                    HorizontalContentAlignment="Stretch"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding ToggleCommand}"
                    Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter />
                        </ControlTemplate>
                    </Button.Template>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon
                            Grid.Column="0"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{Binding AccentBrush}"
                            Symbol="{Binding IconGlyph}" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource OK.FontFamily}"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource Nord.PrimaryTextBrush}"
                            Text="{Binding Label}" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource OK.FontFamily}"
                            FontSize="11"
                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                            Opacity="0.6"
                            Text="{Binding Summary}"
                            TextTrimming="CharacterEllipsis"
                            Visibility="{Binding IsExpanded, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <ui:SymbolIcon
                            Grid.Column="3"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="10"
                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                            Opacity="0.55">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Symbol" Value="ChevronDown24" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                            <Setter Property="Symbol" Value="ChevronUp24" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </Grid>
                </Button>

                <!-- Expanded full content -->
                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="6,6,8,12"
                    Padding="10,8"
                    Background="{StaticResource Nord.CodeBackgroundBrush}"
                    BorderBrush="{StaticResource Nord.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        FontFamily="{StaticResource OK.MonoFontFamily}"
                        FontSize="11.5"
                        Foreground="#FFDCDCE0"
                        Text="{Binding Text}"
                        TextWrapping="Wrap" />
                </Border>
            </Grid>
        </DataTemplate>

        <!-- User-message bubble: right-aligned, muted gray fill,
             soft corners. Outer Grid stretches to fill the row width
             so the inner StackPanel actually reaches the right edge
             of the transcript column on every viewport size. -->
        <DataTemplate x:Key="UserMessageTemplate" DataType="{x:Type vm:ChatMessageRow}">
            <Grid HorizontalAlignment="Stretch" Margin="0,14,0,14">
                <StackPanel HorizontalAlignment="Right">
                <Border
                    MaxWidth="600"
                    Padding="16,12"
                    Background="{StaticResource Nord.UserBubbleBrush}"
                    CornerRadius="14">
                    <TextBlock
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="{StaticResource OK.Font.Body}"
                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                        LineHeight="22"
                        Text="{Binding Text}"
                        TextWrapping="Wrap" />
                </Border>
                <Button
                    Margin="0,6,2,0"
                    HorizontalAlignment="Right"
                    Command="{Binding CopyVisibleTextCommand}"
                    Style="{StaticResource Chat.CopyButtonStyle}">
                    <Grid>
                        <ui:SymbolIcon
                            FontSize="14"
                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                            Symbol="Copy24"
                            Visibility="{Binding JustCopied, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <ui:SymbolIcon
                            FontSize="14"
                            Foreground="{StaticResource Nord.AccentGreenBrush}"
                            Symbol="Checkmark24"
                            Visibility="{Binding JustCopied, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                </Button>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Assistant-message turn: thinking header + timeline + answer.
             Stretch the outer StackPanel so the Final Answer card and
             timeline span the full column width (instead of shrinking
             to their content) — without this, on narrow screens the
             assistant content drifts toward centre because the parent
             ContentControl wraps it tight. -->
        <DataTemplate x:Key="AssistantMessageTemplate" DataType="{x:Type vm:ChatMessageRow}">
            <StackPanel HorizontalAlignment="Stretch" Margin="0,8,0,18">
                <!-- Animated typing indicator — mirrors macOS
                     TypingDotsView (sparkle pulse + three staggered
                     dots). Storyboards live on EventTriggers attached
                     to the panel itself so no code-behind is needed.
                     The panel only mounts while IsAwaitingFirstBlock
                     is true; when the first block arrives the parent
                     collapses this region and the storyboards stop
                     with it. -->
                <StackPanel
                    Margin="0,6,0,10"
                    Orientation="Horizontal"
                    Visibility="{Binding IsAwaitingFirstBlock, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel.Resources>
                        <Storyboard x:Key="TypingPulse" RepeatBehavior="Forever" AutoReverse="True">
                            <!-- Sparkle icon: subtle 0.94 → 1.08 scale +
                                 0.75 → 1.0 opacity, 0.9 s round-trip. -->
                            <DoubleAnimation
                                Storyboard.TargetName="TypingSparkleScale"
                                Storyboard.TargetProperty="ScaleX"
                                From="0.94" To="1.08" Duration="0:0:0.9" />
                            <DoubleAnimation
                                Storyboard.TargetName="TypingSparkleScale"
                                Storyboard.TargetProperty="ScaleY"
                                From="0.94" To="1.08" Duration="0:0:0.9" />
                            <DoubleAnimation
                                Storyboard.TargetName="TypingSparkle"
                                Storyboard.TargetProperty="Opacity"
                                From="0.75" To="1.0" Duration="0:0:0.9" />

                            <!-- Three dots: 0.5 s scale+opacity pulse
                                 with 0.18 s stagger between them. -->
                            <DoubleAnimation
                                Storyboard.TargetName="TypingDot1"
                                Storyboard.TargetProperty="Opacity"
                                From="0.30" To="1.0" Duration="0:0:0.5"
                                BeginTime="0:0:0.00" />
                            <DoubleAnimation
                                Storyboard.TargetName="TypingDot1Scale"
                                Storyboard.TargetProperty="ScaleX"
                                From="0.55" To="1.0" Duration="0:0:0.5"
                                BeginTime="0:0:0.00" />
                            <DoubleAnimation
                                Storyboard.TargetName="TypingDot1Scale"
                                Storyboard.TargetProperty="ScaleY"
                                From="0.55" To="1.0" Duration="0:0:0.5"
                                BeginTime="0:0:0.00" />

                            <DoubleAnimation
                                Storyboard.TargetName="TypingDot2"
                                Storyboard.TargetProperty="Opacity"
                                From="0.30" To="1.0" Duration="0:0:0.5"
                                BeginTime="0:0:0.18" />
                            <DoubleAnimation
                                Storyboard.TargetName="TypingDot2Scale"
                                Storyboard.TargetProperty="ScaleX"
                                From="0.55" To="1.0" Duration="0:0:0.5"
                                BeginTime="0:0:0.18" />
                            <DoubleAnimation
                                Storyboard.TargetName="TypingDot2Scale"
                                Storyboard.TargetProperty="ScaleY"
                                From="0.55" To="1.0" Duration="0:0:0.5"
                                BeginTime="0:0:0.18" />

                            <DoubleAnimation
                                Storyboard.TargetName="TypingDot3"
                                Storyboard.TargetProperty="Opacity"
                                From="0.30" To="1.0" Duration="0:0:0.5"
                                BeginTime="0:0:0.36" />
                            <DoubleAnimation
                                Storyboard.TargetName="TypingDot3Scale"
                                Storyboard.TargetProperty="ScaleX"
                                From="0.55" To="1.0" Duration="0:0:0.5"
                                BeginTime="0:0:0.36" />
                            <DoubleAnimation
                                Storyboard.TargetName="TypingDot3Scale"
                                Storyboard.TargetProperty="ScaleY"
                                From="0.55" To="1.0" Duration="0:0:0.5"
                                BeginTime="0:0:0.36" />
                        </Storyboard>
                    </StackPanel.Resources>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard Storyboard="{StaticResource TypingPulse}" />
                        </EventTrigger>
                    </StackPanel.Triggers>

                    <!-- Pulsing sparkle (matches the AccentPurple used
                         by the thinking section header). -->
                    <ui:SymbolIcon
                        x:Name="TypingSparkle"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource Nord.AccentPurpleBrush}"
                        RenderTransformOrigin="0.5,0.5"
                        Symbol="Sparkle24">
                        <ui:SymbolIcon.RenderTransform>
                            <ScaleTransform x:Name="TypingSparkleScale" ScaleX="0.94" ScaleY="0.94" />
                        </ui:SymbolIcon.RenderTransform>
                    </ui:SymbolIcon>

                    <Ellipse
                        x:Name="TypingDot1"
                        Width="5"
                        Height="5"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Fill="{StaticResource Nord.SecondaryTextBrush}"
                        Opacity="0.55"
                        RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="TypingDot1Scale" ScaleX="0.55" ScaleY="0.55" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse
                        x:Name="TypingDot2"
                        Width="5"
                        Height="5"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Fill="{StaticResource Nord.SecondaryTextBrush}"
                        Opacity="0.55"
                        RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="TypingDot2Scale" ScaleX="0.55" ScaleY="0.55" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse
                        x:Name="TypingDot3"
                        Width="5"
                        Height="5"
                        VerticalAlignment="Center"
                        Fill="{StaticResource Nord.SecondaryTextBrush}"
                        Opacity="0.55"
                        RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="TypingDot3Scale" ScaleX="0.55" ScaleY="0.55" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </StackPanel>

                <!-- Collapsible "Thinking" pill -->
                <Button
                    Margin="0,0,0,0"
                    Padding="0,4"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding ToggleThinkingExpandedCommand}"
                    Cursor="Hand"
                    Visibility="{Binding HasThinking, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter />
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{StaticResource Nord.AccentPurpleBrush}">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Symbol" Value="BrainCircuit24" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                            <Setter Property="Symbol" Value="Sparkle24" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource OK.FontFamily}"
                            FontSize="11.5"
                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                            Text="{Binding ThinkingHeaderText}" />
                        <ui:SymbolIcon
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="10"
                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                            Opacity="0.5">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Symbol" Value="ChevronDown24" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsThinkingExpanded}" Value="True">
                                            <Setter Property="Symbol" Value="ChevronUp24" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </StackPanel>
                </Button>

                <!-- Timeline body — only when expanded -->
                <ItemsControl
                    Margin="2,4,0,0"
                    ItemTemplate="{StaticResource TimelineRowTemplate}"
                    ItemsSource="{Binding ThinkingBlocks}"
                    Visibility="{Binding IsThinkingExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!-- Inline plain assistant text (when no blocks at all) -->
                <TextBlock
                    Margin="0,8,0,0"
                    FontFamily="{StaticResource OK.FontFamily}"
                    FontSize="{StaticResource OK.Font.Body}"
                    Foreground="{StaticResource Nord.AssistantTextBrush}"
                    LineHeight="22"
                    Text="{Binding Text}"
                    TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasPlainText}" Value="True" />
                                        <Condition Binding="{Binding HasFinalAnswer}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Final Answer block — mirrors macOS FinalAnswerView:
                     soft "paper" surface, markdown content on top, copy
                     button anchored bottom-right BELOW the content (the
                     previous DockPanel layout let the button float on
                     top of long markdown headings). -->
                <Border
                    Margin="0,10,0,0"
                    Padding="16,14,16,10"
                    Background="{StaticResource Nord.FinalAnswerSurfaceBrush}"
                    BorderBrush="{StaticResource Nord.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding HasFinalAnswer, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <FlowDocumentScrollViewer
                            Background="Transparent"
                            BorderThickness="0"
                            IsToolBarVisible="False"
                            PreviewMouseWheel="OnInnerScrollableMouseWheel"
                            VerticalScrollBarVisibility="Disabled"
                            md:Markdown.Source="{Binding FinalAnswer.Text}" />
                        <Button
                            Margin="0,6,0,0"
                            HorizontalAlignment="Right"
                            Command="{Binding CopyVisibleTextCommand}"
                            Style="{StaticResource Chat.CopyButtonStyle}"
                            ToolTip="Copy answer">
                            <Grid>
                                <ui:SymbolIcon
                                    FontSize="14"
                                    Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                    Symbol="Copy24"
                                    Visibility="{Binding JustCopied, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                <ui:SymbolIcon
                                    FontSize="14"
                                    Foreground="{StaticResource Nord.AccentGreenBrush}"
                                    Symbol="Checkmark24"
                                    Visibility="{Binding JustCopied, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- System note: centered grey -->
        <DataTemplate x:Key="SystemMessageTemplate" DataType="{x:Type vm:ChatMessageRow}">
            <TextBlock
                Margin="0,6,0,6"
                HorizontalAlignment="Center"
                FontFamily="{StaticResource OK.FontFamily}"
                FontSize="11.5"
                Foreground="{StaticResource Nord.SecondaryTextBrush}"
                Text="{Binding Text}" />
        </DataTemplate>

        <!-- Group section header — clickable to collapse/expand the
             sessions below. Folder icon + group name + count of
             grouped sessions + chevron. Hover surfaces a subtle bg.
             Mirrors macOS SessionPickerView headers (which are also
             collapsible). -->
        <DataTemplate x:Key="SessionGroupHeaderTemplate" DataType="{x:Type vm:SessionGroupHeaderRow}">
            <Button
                Margin="2,10,4,2"
                Padding="4,4"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding ToggleCommand}"
                Cursor="Hand"
                ToolTip="Collapse / expand group">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="HeaderBg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBg" Property="Background" Value="{StaticResource Nord.HoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon
                        Grid.Column="0"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{StaticResource Nord.SecondaryTextBrush}"
                        Opacity="0.7"
                        Symbol="Folder24" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="{StaticResource OK.Font.Eyebrow}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource Nord.SecondaryTextBrush}"
                        Opacity="0.85"
                        Text="{Binding GroupName}"
                        TextTrimming="CharacterEllipsis" />
                    <Border Grid.Column="2" />
                    <TextBlock
                        Grid.Column="3"
                        Margin="6,0,4,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="{StaticResource OK.Font.Eyebrow}"
                        FontWeight="Medium"
                        Foreground="{StaticResource Nord.SecondaryTextBrush}"
                        Opacity="0.55"
                        Text="{Binding SessionCount}" />
                    <ui:SymbolIcon
                        Grid.Column="4"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Foreground="{StaticResource Nord.SecondaryTextBrush}"
                        Opacity="0.65">
                        <ui:SymbolIcon.Style>
                            <Style TargetType="ui:SymbolIcon">
                                <Setter Property="Symbol" Value="ChevronDown24" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                        <Setter Property="Symbol" Value="ChevronRight24" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:SymbolIcon.Style>
                    </ui:SymbolIcon>
                </Grid>
            </Button>
        </DataTemplate>

        <!-- Sidebar session row template. Hovering reveals a small delete
             button at the right edge; clicking it routes through the
             ChatViewModel.DeleteSessionCommand. The button consumes the
             mouse-down event so the row's MouseBinding (open-session)
             doesn't also fire when deleting. -->
        <DataTemplate x:Key="SessionRowTemplate" DataType="{x:Type om:AgentSessionInfo}">
            <Border
                Margin="0,1"
                Padding="0"
                Background="Transparent"
                CornerRadius="6"
                Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding
                        Command="{Binding DataContext.OpenSessionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                        CommandParameter="{Binding}"
                        MouseAction="LeftClick" />
                </Border.InputBindings>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Nord.HoverBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Active session indicator bar -->
                    <Border
                        Grid.Column="0"
                        Width="3"
                        Margin="2,4,0,4"
                        Background="{StaticResource Nord.AccentBrush}"
                        CornerRadius="2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <TextBlock
                        Grid.Column="1"
                        Margin="8,7,0,7"
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="{StaticResource OK.Font.BodyCompact}"
                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                        Text="{Binding Title}"
                        TextTrimming="CharacterEllipsis" />
                    <!-- Delete (X) — only visible while hovering this row.
                         Clicking it does NOT trigger the open-session
                         MouseBinding above because WPF Button suppresses
                         the underlying MouseLeftButtonDown event. -->
                    <Button
                        Grid.Column="2"
                        Width="22"
                        Height="22"
                        Margin="4,0,6,0"
                        Padding="0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                        CommandParameter="{Binding}"
                        Cursor="Hand"
                        ToolTip="Delete chat">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4">
                                    <ui:SymbolIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                        Symbol="Delete24" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{StaticResource Nord.DangerSoftBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <!-- Reveal when the row (ListBoxItem) is hovered. -->
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ────────────────── Sidebar ────────────────── -->
        <Grid
            Grid.Column="0"
            Width="260"
            Margin="14,14,8,14">
            <Grid.RowDefinitions>
                <!-- 0: header, 1: search, 2: divider, 3: session list -->
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header row -->
            <Grid Grid.Row="0" Margin="2,2,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource OK.FontFamily}"
                    FontSize="{StaticResource OK.Font.Headline}"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Nord.PrimaryTextBrush}"
                    Text="OmniAgent" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button
                        Width="30"
                        Height="30"
                        Padding="0"
                        Appearance="Transparent"
                        Command="{Binding NewChatCommand}"
                        Icon="{ui:SymbolIcon Symbol=Compose24, FontSize=14}"
                        ToolTip="New chat" />
                </StackPanel>
            </Grid>

            <!-- Search -->
            <ui:TextBox
                Grid.Row="1"
                Margin="2,0,0,8"
                FontFamily="{StaticResource OK.FontFamily}"
                FontSize="12"
                Icon="{ui:SymbolIcon Symbol=Search24, FontSize=13}"
                PlaceholderText="Search chats"
                Text="{Binding SessionSearchQuery, UpdateSourceTrigger=PropertyChanged}" />

            <Border
                Grid.Row="2"
                Height="1"
                Margin="2,2,0,4"
                Background="{StaticResource Nord.BorderBrush}" />

            <!-- Session list -->
            <Grid Grid.Row="3">
                <!-- Empty state when no sessions exist -->
                <StackPanel
                    Margin="6,16,0,0"
                    Visibility="{Binding SidebarHasSessions, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <TextBlock
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="11.5"
                        Foreground="{StaticResource Nord.SecondaryTextBrush}"
                        Opacity="0.6"
                        Text="No chats yet" />
                </StackPanel>

                <ListBox
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalContentAlignment="Stretch"
                    ItemsSource="{Binding SessionRows}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectedItem="{Binding SelectedSession}"
                    Visibility="{Binding SidebarHasSessions, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ListBox.Resources>
                        <!-- Type-keyed templates. Headers are non-selectable;
                             sessions reuse the existing SessionRowTemplate. -->
                        <DataTemplate DataType="{x:Type vm:SessionGroupHeaderRow}">
                            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource SessionGroupHeaderTemplate}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type om:AgentSessionInfo}">
                            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource SessionRowTemplate}" />
                        </DataTemplate>
                    </ListBox.Resources>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Focusable" Value="True" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <!-- Group headers shouldn't be selectable or
                                     show a focus rect — make them inert. -->
                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                    <Setter Property="IsHitTestVisible" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Grid>

        <Border Grid.Column="1" Background="{StaticResource Nord.BorderBrush}" />

        <!-- ────────────────── Conversation pane ────────────────── -->
        <Grid Grid.Column="2" Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="22,14,22,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <!-- Project eyebrow: uppercase tag of the active session's
                         group. Hidden when the session has no group yet
                         (older sessions, just-started "New Chat"). -->
                    <StackPanel
                        Margin="0,0,0,3"
                        Orientation="Horizontal"
                        Visibility="{Binding HasActiveSessionGroup, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:SymbolIcon
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            FontSize="10"
                            Foreground="{StaticResource Nord.AccentPurpleBrush}"
                            Opacity="0.85"
                            Symbol="Folder24" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource OK.FontFamily}"
                            FontSize="{StaticResource OK.Font.Eyebrow}"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource Nord.AccentPurpleBrush}"
                            Opacity="0.85"
                            Text="{Binding ActiveSessionGroup, Converter={StaticResource ToUpper}}" />
                    </StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                        Text="{Binding ActiveSessionTitle}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:ProgressRing
                        Width="14"
                        Height="14"
                        Margin="0,0,10,0"
                        IsIndeterminate="True"
                        Visibility="{Binding IsLoadingHistory, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="{StaticResource Nord.BorderBrush}" />

            <!-- Transcript -->
            <ScrollViewer
                x:Name="TranscriptScroll"
                Grid.Row="2"
                Padding="22,8,22,8"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <!-- Transcript content is capped at 820 DIP and
                     horizontally centered, mirroring macOS ChatView
                     (".frame(maxWidth: 820).frame(maxWidth: .infinity,
                     alignment: .center)"). On narrow windows the cap
                     is wider than the available space so the column
                     fills the pane; on large monitors the conversation
                     stays a comfortable reading width in the centre. -->
                <!-- HorizontalAlignment=Stretch is critical here: with
                     Center, WPF sizes the Grid to its content's desired
                     width, which collapses the conversation column on
                     narrow windows (user messages drift to centre, etc.).
                     Stretch + MaxWidth makes the Grid fill the pane up
                     to 820 DIP and then cap, so the user bubble sticks
                     to the right edge and the assistant turn sticks
                     to the left edge on every viewport size. -->
                <Grid HorizontalAlignment="Stretch" MaxWidth="820">
                    <!-- Empty state (matches macOS copy) -->
                    <StackPanel
                        MaxWidth="320"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding HasNoMessages, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:SymbolIcon
                            HorizontalAlignment="Center"
                            FontSize="44"
                            Foreground="{StaticResource Nord.AccentBrush}"
                            Opacity="0.55"
                            Symbol="Sparkle24" />
                        <TextBlock
                            Margin="0,14,0,6"
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource OK.FontFamily}"
                            FontSize="{StaticResource OK.Font.Title}"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource Nord.PrimaryTextBrush}"
                            Text="Start a conversation" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource OK.FontFamily}"
                            FontSize="{StaticResource OK.Font.BodyCompact}"
                            Foreground="{StaticResource Nord.SecondaryTextBrush}"
                            Text="Ask anything. Existing chats are in the sidebar."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <ItemsControl
                        Margin="0,0,0,12"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemContainerStyle>
                            <!-- Force every row to fill the column width
                                 so HorizontalAlignment inside templates
                                 (Right for user, Left for assistant)
                                 actually reaches the column edges. -->
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ChatMessageRow}">
                                <ContentControl
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Content="{Binding}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="ContentTemplate" Value="{StaticResource SystemMessageTemplate}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource UserMessageTemplate}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsAssistant}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource AssistantMessageTemplate}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

            <!-- Error bar -->
            <Border
                Grid.Row="3"
                Margin="22,4,22,0"
                Padding="12,8"
                Background="{StaticResource Nord.DangerSoftBrush}"
                BorderBrush="{Binding ErrorBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon
                        Grid.Column="0"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{Binding ErrorBrush}"
                        Symbol="ErrorCircle24" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="12"
                        Foreground="{Binding ErrorBrush}"
                        Text="{Binding LastErrorMessage}"
                        TextWrapping="Wrap" />
                    <ui:Button
                        Grid.Column="2"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Appearance="Transparent"
                        Command="{Binding DismissErrorCommand}"
                        Icon="{ui:SymbolIcon Symbol=Dismiss24, FontSize=12}"
                        ToolTip="Dismiss" />
                </Grid>
            </Border>

            <!-- Composer card — Claude-style: borderless TextBox, soft elevated
                 surface, single focus-ring on the outer card, no internal
                 dividers, generous padding. Capped + centered to match
                 transcript column width on wide monitors. -->
            <Border
                x:Name="ComposerCard"
                Grid.Row="4"
                MaxWidth="820"
                HorizontalAlignment="Stretch"
                Margin="22,10,22,22"
                Padding="0"
                Background="{StaticResource Nord.PanelBackgroundBrush}"
                BorderBrush="{StaticResource Nord.BorderBrush}"
                BorderThickness="1"
                CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="18"
                        Direction="270"
                        Opacity="0.32"
                        ShadowDepth="3"
                        Color="Black" />
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=ComposerCard}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Nord.AccentBrush}" />
                                <Setter Property="BorderThickness" Value="1.5" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="84" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ui:TextBox
                        x:Name="ComposerInput"
                        Grid.Row="0"
                        Margin="16,14,16,4"
                        AcceptsReturn="True"
                        Background="Transparent"
                        BorderThickness="0"
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="{StaticResource OK.Font.Body}"
                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                        MaxHeight="220"
                        PlaceholderText="Ask OmniAgent anything…"
                        Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto">
                        <ui:TextBox.Resources>
                            <!-- Wpf.Ui's TextBox draws an accent underline on
                                 focus via these brushes — override them locally
                                 to Transparent so the inner control has no
                                 bottom border. The outer card already owns the
                                 focus ring. -->
                            <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlFocusedBorderBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                        </ui:TextBox.Resources>
                    </ui:TextBox>

                    <!-- Bottom toolbar: task chip + context indicator + send/stop -->
                    <Grid Grid.Row="1" Margin="12,4,12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Composer pickers cluster (task instruction + project) -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                                                <!-- Task-instruction pill -->
                        <Border
                            Padding="4,2,4,2"
                            VerticalAlignment="Center"
                            CornerRadius="999">
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <ui:SymbolIcon
                                    Margin="4,0,6,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{StaticResource Nord.AccentBrush}"
                                    Symbol="TextBulletListSquare24"
                                    ToolTip="Default task instruction" />
                                <ComboBox
                                    MinWidth="180"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    DisplayMemberPath="Heading"
                                    FontFamily="{StaticResource OK.FontFamily}"
                                    FontSize="12"
                                    ItemsSource="{Binding AvailableTaskTemplates}"
                                    SelectedValue="{Binding SelectedDefaultTemplateId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedValuePath="Id"
                                    ToolTip="Default task instruction (used for Ctrl+T)">
                                    <ComboBox.Resources>
                                        <!-- Drop the Wpf.Ui filled-chip chrome so the
                                             task-instruction selector blends into the
                                             composer toolbar. Popup background is left
                                             alone so the open dropdown stays readable. -->
                                        <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBackground" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#1AFFFFFF" />
                                        <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBackgroundUnfocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBackgroundDisabled" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="Transparent" />
                                    </ComboBox.Resources>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Project / group picker — sits next to the task-
                             instruction chip and stamps the next outbound
                             turn with the chosen group_name. Mirrors the
                             macOS composer "Select project" menu. -->
                        <Border
                            Margin="6,0,0,0"
                            Padding="4,2,4,2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            CornerRadius="999">
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <ui:SymbolIcon
                                    Margin="4,0,6,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{StaticResource Nord.AccentPurpleBrush}"
                                    Symbol="Folder24"
                                    ToolTip="Project for this chat" />
                                <ComboBox
                                    MinWidth="160"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    DisplayMemberPath="DisplayName"
                                    FontFamily="{StaticResource OK.FontFamily}"
                                    FontSize="12"
                                    ItemsSource="{Binding AvailableProjectGroups}"
                                    SelectedValue="{Binding SelectedProjectGroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedValuePath="GroupName"
                                    ToolTip="Project this chat belongs to (mirrors macOS)">
                                    <ComboBox.Resources>
                                        <!-- Match the task-instruction chip
                                             chrome: borderless inside the
                                             toolbar; popup background untouched. -->
                                        <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBackground" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#1AFFFFFF" />
                                        <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBackgroundUnfocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBackgroundDisabled" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="Transparent" />
                                    </ComboBox.Resources>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        </StackPanel>

                        <!-- Spacer between left chip and right cluster -->
                        <Border Grid.Column="1" />

                        <!-- Remaining context window — compact ring; tooltip
                             shows the exact tokens-left numbers. -->
                        <ctl:ContextRing
                            Grid.Column="2"
                            Width="16"
                            Height="16"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Fraction="{Binding ContextUsedFraction}"
                            StrokeThickness="2"
                            TintBrush="{Binding ContextRingBrush}"
                            ToolTip="{Binding ContextSummary}"
                            TrackBrush="{StaticResource Nord.BorderBrush}"
                            Visibility="{Binding HasContextSummary, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <!-- Send / Stop -->
                        <Grid Grid.Column="3">
                            <ui:Button
                                Width="36"
                                Height="36"
                                Padding="0"
                                Appearance="Primary"
                                Command="{Binding SendCommand}"
                                Cursor="Hand"
                                Icon="{ui:SymbolIcon Symbol=ArrowUp24, FontSize=16}"
                                ToolTip="Send (Enter)"
                                Visibility="{Binding IsRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            <ui:Button
                                Width="36"
                                Height="36"
                                Padding="0"
                                Appearance="Danger"
                                Command="{Binding CancelCommand}"
                                Cursor="Hand"
                                Icon="{ui:SymbolIcon Symbol=Stop24, FontSize=14}"
                                ToolTip="Stop"
                                Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
