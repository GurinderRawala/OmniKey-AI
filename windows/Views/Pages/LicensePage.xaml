<Page
    x:Class="OmniKey.Windows.Views.Pages.LicensePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Subscription"
    Background="Transparent"
    d:DesignHeight="600"
    d:DesignWidth="980"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">

    <Grid Margin="24,20,24,20">
        <Border
            MaxWidth="520"
            VerticalAlignment="Center"
            Padding="0"
            Background="{StaticResource Nord.PanelBackgroundBrush}"
            CornerRadius="14">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="22"
                    Direction="270"
                    Opacity="0.45"
                    ShadowDepth="6"
                    Color="Black" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel
                    Grid.Row="0"
                    Margin="0,28,0,20"
                    HorizontalAlignment="Center">
                    <ui:SymbolIcon
                        HorizontalAlignment="Center"
                        FontSize="36"
                        Foreground="{StaticResource Nord.AccentBrush}"
                        Symbol="Key24" />
                    <TextBlock
                        Margin="0,12,0,4"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="{StaticResource OK.Font.Display}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource Nord.PrimaryTextBrush}"
                        Text="Activate OmniKey" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="{StaticResource OK.Font.Body}"
                        Foreground="{StaticResource Nord.SecondaryTextBrush}"
                        Text="Enter your subscription key to unlock all features." />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Height="1"
                    Background="{StaticResource Nord.BorderBrush}" />

                <!-- Self-hosted notice (shown only when ApiClient.IsSelfHosted) -->
                <Border
                    Grid.Row="2"
                    Margin="24,20,24,24"
                    Padding="14,12"
                    Background="{StaticResource Nord.EditorBackgroundBrush}"
                    BorderBrush="{StaticResource Nord.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding IsSelfHosted, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon
                            Margin="0,0,10,0"
                            VerticalAlignment="Top"
                            FontSize="18"
                            Foreground="{StaticResource Nord.AccentGreenBrush}"
                            Symbol="Server24" />
                        <StackPanel>
                            <TextBlock
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.Body}"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource Nord.PrimaryTextBrush}"
                                Text="Self-hosted mode" />
                            <TextBlock
                                Margin="0,4,0,0"
                                MaxWidth="400"
                                FontFamily="{StaticResource OK.FontFamily}"
                                FontSize="{StaticResource OK.Font.Caption}"
                                Foreground="{StaticResource Nord.SecondaryTextBrush}"
                                Text="No subscription key is required. OmniKey is talking to your self-hosted backend and is ready to use."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Form (hidden in self-hosted mode) -->
                <StackPanel
                    Grid.Row="2"
                    Margin="24,20,24,24"
                    Visibility="{Binding IsSelfHosted, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontFamily="{StaticResource OK.FontFamily}"
                        FontSize="{StaticResource OK.Font.CaptionSmall}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource Nord.SecondaryTextBrush}"
                        Text="SUBSCRIPTION KEY" />
                    <ui:TextBox
                        FontFamily="{StaticResource OK.MonoFontFamily}"
                        FontSize="13"
                        PlaceholderText="Paste your subscription key here"
                        Text="{Binding SubscriptionKey, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel
                        Margin="0,18,0,0"
                        Orientation="Horizontal">
                        <ui:ProgressRing
                            Width="14"
                            Height="14"
                            Margin="0,0,8,0"
                            IsIndeterminate="True"
                            Visibility="{Binding IsActivating, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource OK.FontFamily}"
                            FontSize="{StaticResource OK.Font.CaptionSmall}"
                            Foreground="{Binding StatusBrush}"
                            Text="{Binding StatusMessage}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:Button
                            Grid.Column="0"
                            Command="{Binding QuitCommand}"
                            Content="Quit" />
                        <ui:Button
                            Grid.Column="2"
                            Appearance="Primary"
                            Command="{Binding ActivateCommand}"
                            Content="Activate"
                            Icon="{ui:SymbolIcon Symbol=Checkmark24}"
                            IsDefault="True" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
