# ─────────────────────────────────────────────────────────────────────────────
# OmniKey AI — api workspace
#
# Copy this file to `.env` at the repo root (the api workspace reads dotenv
# from the project root) and fill in the values you need. Variables marked
# (required) must be set before `yarn dev` / `yarn start` will boot.
# All others are optional with the documented defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
# Port the HTTP server binds to. Cloud Run also injects PORT=8080.
OMNIKEY_PORT=8080
# winston log level: error | warn | info | debug
LOG_LEVEL=info
# When true, enables self-hosted mode: DATABASE_URL becomes optional and the
# server falls back to a local SQLite file at SQLITE_PATH.
IS_SELF_HOSTED=false
# Internal flag set in local dev builds; toggles a handful of dev-only branches.
LOCAL=false
# When true, refuses requests from SaaS callers (used for self-hosted lockdown).
BLOCK_SAAS=false

# ── AI provider ──────────────────────────────────────────────────────────────
# Pick exactly one provider; the corresponding *_API_KEY below is required.
# If unset, OmniKey auto-detects from whichever key is present.
# Allowed values: openai | anthropic | gemini | nemotron
AI_PROVIDER=openai

# Provider API keys — set the one matching AI_PROVIDER (required for that provider).
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Nemotron / NVIDIA NIM: NEMOTRON_API_KEY wins if both are set.
NVIDIA_API_KEY=
NEMOTRON_API_KEY=
# Optional override to point at a self-hosted NIM gateway.
# Defaults to https://integrate.api.nvidia.com/v1 when unset.
NEMOTRON_BASE_URL=

# ── Database ─────────────────────────────────────────────────────────────────
# Required unless IS_SELF_HOSTED=true. Postgres connection string for SaaS mode.
DATABASE_URL=postgres://omnikey:omnikey_password@localhost:5432/omnikey
# Log every SQL statement Sequelize emits (very chatty — leave false in prod).
DB_LOGGING=false
# Self-hosted SQLite path. Absolute paths are used as-is; relative paths are
# resolved under ~/.omnikey/. Defaults to ~/.omnikey/omnikey-selfhosted.sqlite.
SQLITE_PATH=

# ── Crypto / auth ────────────────────────────────────────────────────────────
# Master key used to encrypt secrets stored in the database (optional in
# self-hosted mode, recommended in SaaS).
APP_ENCRYPTION_KEY=
# JWT signing secret. Change this in any non-local deployment.
JWT_SECRET=default_jwt_secret_change_me
# JWT lifetime in seconds (default: 7200 = 2 hours).
JWT_EXPIRES_IN_SECONDS=7200
# Shared secret used for service-to-service calls (e.g. scheduler → api).
INTERNAL_API_KEY=

# ── Web search providers (all optional; DuckDuckGo is the free fallback) ─────
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
# Self-hosted SearXNG instance URL, e.g. https://searxng.example.com
SEARXNG_URL=

# ── @omniAgent: authenticated browser sessions (CDP) ─────────────────────────
# Populated automatically by `omnikey grant-browser-access`; you usually do
# not need to set these manually.
BROWSER_DEBUG_PORT=
BROWSER_DEBUG_BROWSER_NAME=
BROWSER_DEBUG_EXECUTABLE=
BROWSER_DEBUG_USER_DATA_DIR=

# Forces the agent's terminal tool to assume a specific platform name when
# spawning shells. Leave unset to auto-detect.
TERMINAL_PLATFORM=

# ── GCS download counters (set both to enable) ───────────────────────────────
GCS_BUCKET_NAME=
GCS_DOWNLOAD_COUNT_OBJECT=
