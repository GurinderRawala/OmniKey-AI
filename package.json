{
  "name": "omnikey-ai-api",
  "version": "1.0.26",
  "main": "dist/index.js",
  "description": "Omnikey AI backend API. Use Yarn for install/build/start.",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "format": "prettier --write \"src/**/*.ts\" \"cli/src/**/*.ts\"",
    "dev:windows": "concurrently \"yarn dev\" \"cd windows && dotnet run\""
  },
  "engines": {
    "node": ">=14.0.0",
    "yarn": ">=1.22.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.46.0",
    "axios": "^1.13.5",
    "cors": "^2.8.5",
    "cuid": "^3.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.16.0",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "playwright-core": "^1.50.0",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.6",
    "winston": "^3.19.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "prettier": "^3.3.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  },
  "license": "MIT"
}
