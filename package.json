{
  "name": "omnikey-ai-monorepo",
  "version": "1.6.0",
  "private": true,
  "description": "OmniKey AI monorepo containing the API, CLI, and Telegram workspaces. Use Yarn for install/build/start.",
  "license": "MIT",
  "workspaces": [
    "api",
    "cli",
    "telegram"
  ],
  "engines": {
    "node": ">=14.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "build": "yarn workspace omnikey-ai-api run build && yarn workspace telegram run build && yarn workspace omnikey-cli run build",
    "build:api": "yarn workspace omnikey-ai-api run build",
    "build:telegram": "yarn workspace telegram run build",
    "build:cli": "yarn workspace omnikey-cli run build",
    "dev": "yarn workspace omnikey-ai-api run dev",
    "start": "yarn workspace omnikey-ai-api run start",
    "test": "yarn workspaces run test",
    "lint": "yarn workspaces run lint",
    "format": "yarn workspaces run format",
    "clean": "yarn workspaces run clean"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.7.2"
  }
}
