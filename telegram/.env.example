# ─────────────────────────────────────────────────────────────────────────────
# OmniKey AI — telegram workspace
#
# Copy this file to `.env` at the repo root (the telegram service loads
# dotenv from the current working directory) and fill in the values for
# your bot. See ./README.md for the BotFather + chat-ID walkthrough.
# ─────────────────────────────────────────────────────────────────────────────

# ── Bot credentials (required) ───────────────────────────────────────────────
# Bot token returned by @BotFather after `/newbot`. Treat it like a password.
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ-0123456789
# Chat ID this bot is allowed to talk to. Group/channel IDs are negative —
# keep the minus sign. See README.md → "Find your chat ID" for how to grab it.
TELEGRAM_CHAT_ID=123456789

# ── Local HTTP listener ──────────────────────────────────────────────────────
# Port the telegram daemon binds for its incoming notify webhook. Defaults to
# 6666 when unset. The OmniKey CLI talks to this port for `notify` calls.
PORT=6666

# ── Misc ─────────────────────────────────────────────────────────────────────
# winston log level: error | warn | info | debug
LOG_LEVEL=info

# The Telegram service reads the OmniKey backend URL and SQLite path from
# ~/.omnikey/config.json (managed by `omnikey onboard` / `omnikey set`),
# not from this file. No further variables are needed here.
