{
  "name": "omnikey-cli",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "version": "1.0.25",
  "description": "CLI for onboarding users to Omnikey AI and configuring OPENAI_API_KEY. Use Yarn for install/build.",
  "engines": {
    "node": ">=14.0.0",
    "yarn": ">=1.22.0"
  },
  "bin": {
    "omnikey": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "copy-backend": "rm -rf backend-dist && mkdir -p backend-dist && cp -R ../dist/* backend-dist/"
  },
  "keywords": [
    "cli",
    "omnikey",
    "onboarding",
    "openai"
  ],
  "author": "Gurinder Rawala",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.0.0",
    "inquirer": "^9.0.0",
    "axios": "^1.13.5",
    "cors": "^2.8.5",
    "cuid": "^3.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.16.0",
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.46.0",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.6",
    "winston": "^3.19.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6",
    "playwright-core": "^1.50.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GurinderRawala/OmniKey-AI.git"
  },
  "files": [
    "dist",
    "backend-dist",
    "src",
    "README.md"
  ]
}
