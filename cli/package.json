{
  "name": "omnikey-cli",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "version": "1.6.7",
  "description": "CLI for onboarding users to Omnikey AI and configuring OPENAI_API_KEY. Use Yarn for install/build.",
  "engines": {
    "node": ">=14.0.0",
    "yarn": ">=1.22.0"
  },
  "bin": {
    "omnikey": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && yarn run copy-backend && yarn run build:telegram-client",
    "start": "node dist/index.js",
    "copy-backend": "rm -rf backend-dist && mkdir -p backend-dist && cp -R ../api/dist/* backend-dist/",
    "build:telegram-client": "rm -rf telegram-client-dist && mkdir -p telegram-client-dist && cp -R ../telegram/dist/* telegram-client-dist/",
    "clean": "rm -rf dist backend-dist telegram-client-dist",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "echo \"(no tests in this workspace)\" && exit 0",
    "lint": "echo \"(no lint in this workspace)\" && exit 0"
  },
  "keywords": [
    "cli",
    "omnikey",
    "onboarding",
    "openai"
  ],
  "author": "Gurinder Rawala",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@google-cloud/storage": "^7.19.0",
    "@google/genai": "^1.46.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.13.5",
    "commander": "^11.0.0",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "cuid": "^3.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "inquirer": "^9.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-telegram-bot-api": "^0.61.0",
    "openai": "^6.37.0",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "playwright-core": "^1.50.0",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.6",
    "winston": "^3.19.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node-telegram-bot-api": "^0.64.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GurinderRawala/OmniKey-AI.git"
  },
  "files": [
    "dist",
    "backend-dist",
    "src",
    "README.md",
    "telegram-client-dist"
  ]
}
